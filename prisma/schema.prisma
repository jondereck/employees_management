generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DATABASE_URL_UNPOOLED")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  relationMode      = "foreignKeys"
}

model Department {
  id                          String                       @id @default(uuid())
  name                        String
  userId                      String
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  billboards                  Billboard[]                  @relation("DepartmentToBillboard")
  ChangeRequest               ChangeRequest[]
  employee                    Employee[]                   @relation("DepartmentToEmployee")
  employeeHistorySnapshots    EmployeeHistorySnapshot[]
  offices                     Offices[]                    @relation("DepartmentToOffices")
  orgChartVersions            OrgChartVersion[]
  officeWorkSchedules         OfficeWorkSchedule[]
  timekeepingAnalyzerSettings TimekeepingAnalyzerSetting[]
  workforceReportGroups       WorkforceReportGroup[]
  workforceReportCaches       WorkforceReportCache[]
}

model OrgChartVersion {
  id           String     @id @default(cuid())
  departmentId String
  label        String
  data         Json
  isDefault    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([departmentId, id])
}

model Billboard {
  id           String     @id @default(uuid())
  departmentId String
  label        String
  imageUrl     String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  bioIndexCode String?    @db.VarChar(16)
  department   Department @relation("DepartmentToBillboard", fields: [departmentId], references: [id], onUpdate: NoAction, map: "billboard_departmentid_fkey")
  offices      Offices[]

  @@index([departmentId])
}

model Offices {
  id                          String                       @id @default(uuid())
  departmentId                String
  billboardId                 String
  name                        String
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  bioIndexCode                String?                      @db.VarChar(16)
  designatedEmployees         Employee[]                   @relation("OfficesToDesignation")
  employee                    Employee[]                   @relation("OfficesToEmployee")
  employeeHistorySnapshots    EmployeeHistorySnapshot[]
  billboard                   Billboard                    @relation(fields: [billboardId], references: [id], onUpdate: NoAction, map: "offices_billboardid_fkey")
  department                  Department                   @relation("DepartmentToOffices", fields: [departmentId], references: [id], onUpdate: NoAction, map: "offices_departmentid_fkey")
  officeWorkSchedules         OfficeWorkSchedule[]
  workforceReportGroupOffices WorkforceReportGroupOffice[]

  @@index([departmentId])
  @@index([billboardId])
  @@index([bioIndexCode])
}

model EmployeeType {
  id                       String                    @id @default(uuid())
  departmentId             String
  name                     String
  value                    String
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  employee                 Employee[]
  employeeHistorySnapshots EmployeeHistorySnapshot[]

  @@index([departmentId])
}

model Eligibility {
  id                       String                    @id @default(uuid())
  departmentId             String
  eligibilityTypes         EligibilityTypes
  name                     String
  value                    String
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  employee                 Employee[]
  employeeHistorySnapshots EmployeeHistorySnapshot[]

  @@index([departmentId])
}

model Employee {
  id                     String                    @id @default(uuid())
  departmentId           String
  officeId               String
  prefix                 String                    @default("")
  lastName               String
  firstName              String
  middleName             String
  suffix                 String
  gender                 Gender
  contactNumber          String
  position               String
  education              String
  birthday               DateTime
  age                    String                    @default("")
  region                 String                    @default("")
  province               String                    @default("")
  city                   String                    @default("")
  barangay               String                    @default("")
  houseNo                String                    @default("")
  street                 String                    @default("")
  gsisNo                 String?
  tinNo                  String?
  philHealthNo           String?
  pagIbigNo              String?
  salary                 Float
  dateHired              DateTime
  latestAppointment      String                    @default("")
  terminateDate          String                    @default("")
  memberPolicyNo         String?
  employeeTypeId         String
  eligibilityId          String
  isFeatured             Boolean                   @default(false)
  isArchived             Boolean                   @default(false)
  isHead                 Boolean                   @default(false)
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  emergencyContactName   String                    @default("")
  emergencyContactNumber String                    @default("")
  isAwardee              Boolean                   @default(false)
  nickname               String                    @default("")
  employeeNo             String                    @default("")
  employeeLink           String                    @default("")
  salaryStep             Int?
  salaryGrade            Int?
  designationId          String?
  note                   String?
  publicId               String                    @unique @default(dbgenerated("gen_random_uuid()"))
  publicEnabled          Boolean                   @default(false)
  publicVersion          Int                       @default(1)
  salaryMode             SalaryMode                @default(AUTO)
  legacyQrAllowed        Boolean                   @default(true)
  maritalStatus          MaritalStatus?
  email                  String?                   @unique
  philSysNumber          String?                   @unique
  awards                 Award[]
  biometricsIdentityMaps BiometricsIdentityMap[]   @relation("EmployeeToBiometricsIdentityMaps")
  changeRequests         ChangeRequest[]           @relation("EmployeeToChangeRequests")
  department             Department                @relation("DepartmentToEmployee", fields: [departmentId], references: [id], onUpdate: NoAction, map: "employee_departmentid_fkey")
  designation            Offices?                  @relation("OfficesToDesignation", fields: [designationId], references: [id], onUpdate: NoAction, map: "employee_designationid_fkey")
  eligibility            Eligibility               @relation(fields: [eligibilityId], references: [id], onUpdate: NoAction, map: "employee_eligibilityid_fkey")
  employeeType           EmployeeType              @relation(fields: [employeeTypeId], references: [id], onUpdate: NoAction, map: "employee_employeetypeid_fkey")
  offices                Offices                   @relation("OfficesToEmployee", fields: [officeId], references: [id], onUpdate: NoAction, map: "employee_officeid_fkey")
  historySnapshots       EmployeeHistorySnapshot[]
  employmentEvents       EmploymentEvent[]
  images                 Image[]
  scheduleExceptions     ScheduleException[]
  weeklyExclusions       WeeklyExclusion[]
  workSchedules          WorkSchedule[]

  @@index([departmentId])
  @@index([officeId])
  @@index([employeeTypeId])
  @@index([eligibilityId])
  @@index([designationId])
}

model EmployeeHistorySnapshot {
  id             String                @id @default(cuid())
  departmentId   String
  employeeId     String
  effectiveAt    DateTime
  officeId       String?
  employeeTypeId String?
  eligibilityId  String?
  position       String                @default("")
  gender         Gender?
  maritalStatus  MaritalStatus?
  isHead         Boolean               @default(false)
  status         String                @default("ACTIVE")
  indicatorId    String?
  source         String                @default("MANUAL")
  note           String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  department     Department            @relation(fields: [departmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  employee       Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  office         Offices?              @relation(fields: [officeId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  employeeType   EmployeeType?         @relation(fields: [employeeTypeId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  eligibility    Eligibility?          @relation(fields: [eligibilityId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  indicator      WorkforceReportGroup? @relation(fields: [indicatorId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([departmentId, effectiveAt])
  @@index([employeeId, effectiveAt])
  @@index([departmentId, employeeId, effectiveAt])
  @@index([officeId])
  @@index([employeeTypeId])
  @@index([eligibilityId])
  @@index([indicatorId])
}

model WorkforceReportGroup {
  id           String                       @id @default(cuid())
  departmentId String
  name         String
  sortOrder    Int                          @default(0)
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt
  department   Department                   @relation(fields: [departmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  offices      WorkforceReportGroupOffice[]
  snapshots    EmployeeHistorySnapshot[]

  @@unique([departmentId, name])
  @@index([departmentId, sortOrder])
}

model WorkforceReportGroupOffice {
  id        String               @id @default(cuid())
  groupId   String
  officeId  String
  createdAt DateTime             @default(now())
  group     WorkforceReportGroup @relation(fields: [groupId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  office    Offices              @relation(fields: [officeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([groupId, officeId])
  @@index([officeId])
}

model WorkforceReportCache {
  id                String     @id @default(cuid())
  departmentId      String
  year              Int
  populationMode    String
  dimension         String
  selectedGroupHash String
  selectedGroupIds  Json
  version           Int        @default(1)
  payload           Json
  generatedAt       DateTime   @default(now())
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  department        Department @relation(fields: [departmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([departmentId, year, populationMode, dimension, selectedGroupHash, version])
  @@index([departmentId, year])
}

model Image {
  id         String   @id @default(uuid())
  employeeId String
  url        String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "image_employeeid_fkey")

  @@index([employeeId])
}

model Salary {
  id     Int   @id @default(autoincrement())
  grade  Int
  step   Int
  amount Float

  @@unique([grade, step])
}

model EmploymentEvent {
  id         String              @id @default(dbgenerated("gen_random_uuid()"))
  employeeId String
  type       EmploymentEventType
  details    String?
  occurredAt DateTime
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  deletedAt  DateTime?
  employee   Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, occurredAt])
}

model Award {
  id          String    @id @default(dbgenerated("gen_random_uuid()"))
  employeeId  String
  title       String
  description String?
  givenAt     DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  issuer      String?
  thumbnail   String?
  fileUrl     String?
  tags        String[]  @default([])
  deletedAt   DateTime?
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model BiometricsIdentityMap {
  token      String   @id
  employeeId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation("EmployeeToBiometricsIdentityMaps", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model ChangeRequest {
  id             String       @id @default(uuid())
  departmentId   String
  employeeId     String
  entityType     ChangeEntity
  entityId       String?
  action         ChangeAction
  status         ChangeStatus @default(PENDING)
  oldValues      Json?
  newValues      Json?
  note           String?
  submittedName  String?
  submittedEmail String?
  ipHash         String?
  reviewedAt     DateTime?
  approvedById   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
  Department     Department   @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "changerequest_departmentid_fkey")
  employee       Employee     @relation("EmployeeToChangeRequests", fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "changerequest_employeeid_fkey")

  @@index([departmentId, status, createdAt], map: "changerequest_dept_status_created_idx")
  @@index([employeeId], map: "changerequest_employeeid_idx")
  @@index([entityType, entityId], map: "changerequest_entitytype_entityid_idx")
}

model WorkSchedule {
  id                   String       @id @default(cuid())
  employeeId           String
  type                 ScheduleType
  startTime            String?
  endTime              String?
  graceMinutes         Int?
  coreStart            String?
  coreEnd              String?
  bandwidthStart       String?
  bandwidthEnd         String?
  requiredDailyMinutes Int?
  shiftStart           String?
  shiftEnd             String?
  breakMinutes         Int          @default(60)
  timezone             String       @default("Asia/Manila")
  effectiveFrom        DateTime
  effectiveTo          DateTime?
  weeklyPattern        Json?
  employee             Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "workschedule_employeeid_fkey")

  @@index([employeeId, effectiveFrom, effectiveTo])
}

model OfficeWorkSchedule {
  id                   String       @id @default(cuid())
  departmentId         String
  officeId             String
  type                 ScheduleType
  startTime            String?
  endTime              String?
  graceMinutes         Int?
  coreStart            String?
  coreEnd              String?
  bandwidthStart       String?
  bandwidthEnd         String?
  requiredDailyMinutes Int?
  shiftStart           String?
  shiftEnd             String?
  breakMinutes         Int          @default(60)
  timezone             String       @default("Asia/Manila")
  effectiveFrom        DateTime
  effectiveTo          DateTime?
  weeklyPattern        Json?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  department           Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  office               Offices      @relation(fields: [officeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([departmentId, officeId, effectiveFrom, effectiveTo])
  @@index([officeId, effectiveFrom, effectiveTo])
}

model TimekeepingAnalyzerSetting {
  id           String     @id @default(cuid())
  departmentId String
  userId       String     @default("")
  scope        String
  key          String
  value        Json
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([departmentId, userId, scope, key])
  @@index([departmentId, scope, key])
  @@index([departmentId, userId])
}

model ScheduleException {
  id                   String       @id @default(cuid())
  employeeId           String
  date                 DateTime
  type                 ScheduleType
  startTime            String?
  endTime              String?
  graceMinutes         Int?
  coreStart            String?
  coreEnd              String?
  bandwidthStart       String?
  bandwidthEnd         String?
  requiredDailyMinutes Int?
  shiftStart           String?
  shiftEnd             String?
  breakMinutes         Int?
  employee             Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "scheduleexception_employeeid_fkey")

  @@index([employeeId, date])
}

model WeeklyExclusion {
  id            String    @id @default(cuid())
  employeeId    String
  weekday       Int
  mode          String
  ignoreUntil   DateTime?
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "weeklyexclusion_employeeid_fkey")

  @@index([employeeId, weekday, effectiveFrom, effectiveTo])
}

enum SalaryMode {
  AUTO
  MANUAL
}

enum EligibilityTypes {
  None
  Professional
  SubProffessional
}

enum Gender {
  Male
  Female
}

enum EmploymentEventType {
  HIRED
  PROMOTED
  TRANSFERRED
  REASSIGNED
  AWARDED
  CONTRACT_RENEWAL
  TERMINATED
  OTHER
}

enum ChangeEntity {
  AWARD
  TIMELINE
}

enum ChangeAction {
  CREATE
  UPDATE
  DELETE
}

enum ChangeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ScheduleType {
  FIXED
  FLEX
  SHIFT
}

enum MaritalStatus {
  SINGLE
  MARRIED
  SEPARATED
  WIDOWED
  DIVORCED
}
